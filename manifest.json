{
  "manifest_version": 3,
  "name": "ChimeIn",
  "version": "1.0.0",
  "description": "Never miss a hackathon deadline again",
  "permissions": ["identity", "storage", "tabs", "sidePanel", "scripting"],
  "host_permissions": ["<all_urls>"],
  "oauth2": {
    "client_id": "1084139317632-adm3j5v8897l2c3e17m37886tagbg6ro.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/calendar.events"]
  },
  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/extractor.js"]
    }
  ]
}